# .env.local — copie este arquivo e preencha os valores
# NUNCA commit o .env.local com os valores reais

# MongoDB Atlas
# Crie em: https://cloud.mongodb.com
# Connection string: mongodb+srv://usuario:senha@cluster.mongodb.net/nfe-licenses
MONGODB_URI=mongodb+srv://USUARIO:SENHA@CLUSTER.mongodb.net/nfe-licenses

# Resend (email)
# Crie em: https://resend.com — gratis ate 100 emails/dia
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX

# Remetente do email — precisa ser um dominio verificado no Resend
EMAIL_FROM=NF-e Desktop <noreply@SEUDOMINIO.com.br>

# Token secreto do webhook Hotmart
# Configure em: Hotmart > Ferramentas > Webhooks > Token
HOTMART_WEBHOOK_TOKEN=SEU_TOKEN_SECRETO_AQUI

# JWT para proteger rotas do painel admin
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERE_UM_TOKEN_ALEATORIO_LONGO_AQUI

# URL publica da API (sem barra no final)
NEXT_PUBLIC_API_URL=https://nfe-license-api.vercel.app
